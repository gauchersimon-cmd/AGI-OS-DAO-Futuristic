{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Backend (Litestar)",
      "type": "shell",
      "command": "python",
      "args": ["backend/main.py"],
      "cwd": "${workspaceFolder}",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Application startup complete.*",
          "endsPattern": "^.*Application shutdown complete.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "panelReuse": "dedicated"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "📱 Frontend (Next.js)",
      "type": "shell",
      "command": "pnpm",
      "args": ["dev"],
      "cwd": "${workspaceFolder}",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Ready in.*",
          "endsPattern": "^.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "panelReuse": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "⚡ Both Servers (Backend + Frontend)",
      "dependsOn": ["🚀 Backend (Litestar)", "📱 Frontend (Next.js)"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "🔧 Install Backend Dependencies",
      "type": "shell",
      "command": "pip",
      "args": ["install", "-r", "backend/requirements.txt"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "📦 Install Frontend Dependencies",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "🏗️ Build Frontend",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "📋 Run Tests (Backend)",
      "type": "shell",
      "command": "python",
      "args": ["-m", "pytest", "backend/tests", "-v"],
      "cwd": "${workspaceFolder}",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
